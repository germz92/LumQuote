MONGODB_URI=mongodb://localhost:27017/LumetryMedia
PORT=3000
JWT_SECRET=your-jwt-secret
SESSION_SECRET=your-session-secret

# Cloudinary (profile photos — same account as LumDash recommended)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# LumDash stores users in the default "test" db; LumQuote uses LumetryMedia
LUMDASH_DB_NAME=test
# Optional: folder for LumQuote uploads (LumDash uses lumdash/profile-photos)
# CLOUDINARY_PROFILE_FOLDER=lumquote/profile-photos
